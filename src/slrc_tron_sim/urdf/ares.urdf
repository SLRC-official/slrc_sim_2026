<?xml version="1.0"?>
<robot name="ares">
  <!-- =============================================================================
       ARES - Ego Robot (Contestant-controlled)
       SLRC 2026 Competition | Contact: slrc@uom.lk
       ============================================================================= -->

  <!-- =========================
       Frames
       ========================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       Base link
       ========================= -->
  <link name="base_link">
    <inertial>
      <!-- align inertia origin with bbox collision center -->
      <origin xyz="0 0 0.041" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.003387" ixy="0.0" ixz="0.0"
               iyy="0.012987" iyz="0.0"
               izz="0.012000"/>
    </inertial>

    <visual name="lightcycle_visual">
      <origin xyz="-0.09 0.027 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://slrc_tron_sim/meshes/lightcycle.STL" scale="0.001 0.001 0.0015"/>
      </geometry>
      <material name="ares_red">
        <color rgba="1.0 0.05 0.15 1.0"/>
      </material>
    </visual>

    <collision name="chassis_bbox">
      <!-- center the box around the bike's center-of-mass-ish -->
      <origin xyz="0 0 0.041" rpy="0 0 0"/>
      <geometry>
        <!-- L, W, H -->
        <box size="0.18 0.06 0.081"/>
      </geometry>
    </collision>
  </link>

  <!-- =========================
       Wheels (Diff Drive)
       ========================= -->
  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>

    <collision name="left_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>

    <collision name="right_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.0 0.05 0.033" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.05 0.033" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- =========================
       LED
       ========================= -->
  <link name="led_link">
    <!-- Cylinder base -->
    <visual name="led_base_vis">
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.005" length="0.015"/>
      </geometry>
      <material name="led_base_red">
        <color rgba="1.0 0.05 0.15 1.0"/>
      </material>
    </visual>

    <!-- Dome: sit on top of cylinder -->
    <visual name="led_dome_vis">
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <material name="led_glow_blue">
        <color rgba="0.10 0.40 1.00 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="led_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="led_link"/>
    <origin xyz="-0.05 0 0.058" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       Cameras (2 front + 1 floor)
       ========================= -->
  <link name="cam_front_left_link"/>
  <link name="cam_front_right_link"/>
  <link name="cam_floor_link"/>

  <joint name="cam_front_left_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="cam_front_left_link"/>
    <origin xyz="0.45 0.10 0.45" rpy="0 0 0"/>
  </joint>

  <joint name="cam_front_right_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="cam_front_right_link"/>
    <origin xyz="0.45 -0.10 0.45" rpy="0 0 0"/>
  </joint>

  <joint name="cam_floor_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="cam_floor_link"/>
    <origin xyz="0.15 0.0 0.18" rpy="0 1.5708 0"/>
  </joint>

  <!-- =========================
       IMU frame
       ========================= -->
  <link name="imu_link"/>
  <joint name="imu_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================
       Gazebo Sim (Ignition): Plugins and sensors
       ========================================================= -->

  <gazebo>
    <plugin
      filename="libignition-gazebo-diff-drive-system.so"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.1</wheel_separation>
      <wheel_radius>0.033</wheel_radius>

      <topic>/ares/cmd_vel</topic>
      <odom_topic>/ares/odom</odom_topic>
      <tf_topic>/ares/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>100</odom_publish_frequency>

      <!-- limits -->
      <max_linear_acceleration>5</max_linear_acceleration>
      <max_angular_acceleration>10</max_angular_acceleration>
    </plugin>
  </gazebo>

  <!-- Front-left camera -->
  <gazebo reference="cam_front_left_link">
    <sensor name="cam_front_left" type="camera">
      <topic>/ares/front_left/image_raw</topic>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Front-right camera -->
  <gazebo reference="cam_front_right_link">
    <sensor name="cam_front_right" type="camera">
      <topic>/ares/front_right/image_raw</topic>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Floor camera -->
  <gazebo reference="cam_floor_link">
    <sensor name="cam_floor" type="camera">
      <topic>/ares/floor/image_raw</topic>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>10</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- IMU -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <topic>/ares/imu/data</topic>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

</robot>
